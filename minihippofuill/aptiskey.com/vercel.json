{
  "version": 2,
  "builds": [
    {
      "src": "api/ask.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/upload-audio.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/upload-lesson.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/visitor-count.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/auth/[action].js",
      "use": "@vercel/node"
    },
    {
      "src": "api/devices/[action].js",
      "use": "@vercel/node"
    },
    {
      "src": "api/lessons/[action].js",
      "use": "@vercel/node"
    },
    {
      "src": "api/practice_results/[action].js",
      "use": "@vercel/node"
    },
    {
      "src": "api/practice_sets/[action].js",
      "use": "@vercel/node"
    },
    {
      "src": "api/users/[action].js",
      "use": "@vercel/node"
    },
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/ask",
      "destination": "/api/ask.js"
    },
    {
      "source": "/api/upload-audio",
      "destination": "/api/upload-audio.js"
    },
    {
      "source": "/api/upload-lesson",
      "destination": "/api/upload-lesson.js"
    },
    {
      "source": "/api/visitor-count",
      "destination": "/api/visitor-count.js"
    },
    {
      "source": "/api/auth/:action",
      "destination": "/api/auth/[action].js?action=:action"
    },
    {
      "source": "/api/devices/:action",
      "destination": "/api/devices/[action].js?action=:action"
    },
    {
      "source": "/api/lessons/:action",
      "destination": "/api/lessons/[action].js?action=:action"
    },
    {
      "source": "/api/practice_results/:action",
      "destination": "/api/practice_results/[action].js?action=:action"
    },
    {
      "source": "/api/practice_sets/:action",
      "destination": "/api/practice_sets/[action].js?action=:action"
    },
    {
      "source": "/api/users/:action",
      "destination": "/api/users/[action].js?action=:action"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
