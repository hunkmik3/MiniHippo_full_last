{
  "version": 2,
  "builds": [
    {
      "src": "minihippofuill/aptiskey.com/api/ask.js",
      "use": "@vercel/node"
    },
    {
      "src": "minihippofuill/aptiskey.com/api/upload-audio.js",
      "use": "@vercel/node"
    },
    {
      "src": "minihippofuill/aptiskey.com/api/upload-lesson.js",
      "use": "@vercel/node"
    },
    {
      "src": "minihippofuill/aptiskey.com/api/visitor-count.js",
      "use": "@vercel/node"
    },
    {
      "src": "minihippofuill/aptiskey.com/api/auth/[action].js",
      "use": "@vercel/node"
    },
    {
      "src": "minihippofuill/aptiskey.com/api/devices/[action].js",
      "use": "@vercel/node"
    },
    {
      "src": "minihippofuill/aptiskey.com/api/lessons/[action].js",
      "use": "@vercel/node"
    },
    {
      "src": "minihippofuill/aptiskey.com/api/practice_results/[action].js",
      "use": "@vercel/node"
    },
    {
      "src": "minihippofuill/aptiskey.com/api/practice_sets/[action].js",
      "use": "@vercel/node"
    },
    {
      "src": "minihippofuill/aptiskey.com/api/users/[action].js",
      "use": "@vercel/node"
    },
    {
      "src": "minihippofuill/aptiskey.com/**/*",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/ask",
      "destination": "/minihippofuill/aptiskey.com/api/ask.js"
    },
    {
      "source": "/api/upload-audio",
      "destination": "/minihippofuill/aptiskey.com/api/upload-audio.js"
    },
    {
      "source": "/api/upload-lesson",
      "destination": "/minihippofuill/aptiskey.com/api/upload-lesson.js"
    },
    {
      "source": "/api/visitor-count",
      "destination": "/minihippofuill/aptiskey.com/api/visitor-count.js"
    },
    {
      "source": "/api/auth/:action",
      "destination": "/minihippofuill/aptiskey.com/api/auth/[action].js?action=:action"
    },
    {
      "source": "/api/devices/:action",
      "destination": "/minihippofuill/aptiskey.com/api/devices/[action].js?action=:action"
    },
    {
      "source": "/api/lessons/:action",
      "destination": "/minihippofuill/aptiskey.com/api/lessons/[action].js?action=:action"
    },
    {
      "source": "/api/practice_results/:action",
      "destination": "/minihippofuill/aptiskey.com/api/practice_results/[action].js?action=:action"
    },
    {
      "source": "/api/practice_sets/:action",
      "destination": "/minihippofuill/aptiskey.com/api/practice_sets/[action].js?action=:action"
    },
    {
      "source": "/api/users/:action",
      "destination": "/minihippofuill/aptiskey.com/api/users/[action].js?action=:action"
    },
    {
      "source": "/(.*)",
      "destination": "/minihippofuill/aptiskey.com/$1"
    }
  ],
  "cleanUrls": false,
  "trailingSlash": false
}
