{
  "version": 2,
  "builds": [
    {
      "src": "minihippofuill/aptiskey.com/api/ask.js",
      "use": "@vercel/node"
    },
    {
      "src": "minihippofuill/aptiskey.com/api/upload-audio.js",
      "use": "@vercel/node"
    },
    {
      "src": "minihippofuill/aptiskey.com/api/upload-lesson.js",
      "use": "@vercel/node"
    },
    {
      "src": "minihippofuill/aptiskey.com/api/visitor-count.js",
      "use": "@vercel/node"
    },
    {
      "src": "minihippofuill/aptiskey.com/api/auth/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "minihippofuill/aptiskey.com/api/devices/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "minihippofuill/aptiskey.com/api/lessons/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "minihippofuill/aptiskey.com/api/practice_results/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "minihippofuill/aptiskey.com/api/practice_sets/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "minihippofuill/aptiskey.com/api/users/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "minihippofuill/aptiskey.com/**/*",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/auth/(.*)",
      "destination": "/minihippofuill/aptiskey.com/api/auth/$1.js"
    },
    {
      "source": "/api/devices/(.*)",
      "destination": "/minihippofuill/aptiskey.com/api/devices/$1.js"
    },
    {
      "source": "/api/lessons/(.*)",
      "destination": "/minihippofuill/aptiskey.com/api/lessons/$1.js"
    },
    {
      "source": "/api/practice_results/(.*)",
      "destination": "/minihippofuill/aptiskey.com/api/practice_results/$1.js"
    },
    {
      "source": "/api/practice_sets/(.*)",
      "destination": "/minihippofuill/aptiskey.com/api/practice_sets/$1.js"
    },
    {
      "source": "/api/users/(.*)",
      "destination": "/minihippofuill/aptiskey.com/api/users/$1.js"
    },
    {
      "source": "/(.*)",
      "destination": "/minihippofuill/aptiskey.com/$1"
    }
  ],
  "cleanUrls": false,
  "trailingSlash": false
}
